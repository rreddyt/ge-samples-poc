# ==============================================================================
# Generic Retail Store — Product SKU Enrichment Agent Environment Template
# ==============================================================================
# Copy this file to a file named ".env" in the same directory and customize
# the parameters to execute the agent workflow in your own GCP project.

# ------------------------------------------------------------------------------
# 1. Google Cloud Platform (GCP) Project & Location Config
# ------------------------------------------------------------------------------
# Your Google Cloud Project ID (e.g. my-retail-staging-project)
GCP_PROJECT_ID=your-gcp-project-id

# Vertex AI Generative AI and Imagen 3 model region (e.g. us-central1)
GCP_LOCATION=us-central1

# ------------------------------------------------------------------------------
# 2. BigQuery Database Structure
# ------------------------------------------------------------------------------
# BigQuery dataset name containing both tables (e.g. retail_catalog_dataset)
BQ_DATASET=retail_catalog_dataset

# BigQuery source table name containing columns: sku, name, description, images_gcs_folder
BQ_PRODUCTS_TABLE=products

# BigQuery destination table name to store the generated product tags
BQ_TAGS_TABLE=product_tags

# ------------------------------------------------------------------------------
# 3. Cloud Storage Structure
# ------------------------------------------------------------------------------
# GCS bucket name to store the generated marketing lifestyle images (.png)
# Note: GCS bucket names must be globally unique across all GCP users.
GCS_BUCKET_NAME=retail_product_media_your_project_id

# ------------------------------------------------------------------------------
# 4. Corporate Developer Workstation mTLS Bypass Config
# ------------------------------------------------------------------------------
# These settings prevent "MutualTLSChannelError: Cert provider command returns -11"
# errors on gLinux or corporate workstations by disabling client certificate checking.
GOOGLE_API_USE_CLIENT_CERTIFICATE=false
GOOGLE_API_USE_MTLS_ENDPOINT=never
