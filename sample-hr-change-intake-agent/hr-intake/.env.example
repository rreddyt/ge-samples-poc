# =====================================================================
# HR Personnel Change Intake Agent - Configuration Template
# =====================================================================

# ☁️ Google Cloud Platform Settings
GOOGLE_CLOUD_PROJECT=<your-gcp-project-id>
GOOGLE_CLOUD_REGION=us-central1
GOOGLE_CLOUD_LOCATION=us-central1

# 🎫 Jira Connection Configuration (Mock/Local by default, set to true for Connector)
USE_JIRA_INTEGRATION_CONNECTOR=false
JIRA_CONNECTION_NAME=jira-connector

# 🏢 Microsoft Graph (Entra ID) Remote MCP Server (Optional: set if deployed in Cloud Run)
# Format: https://<your-msft-run-url>/mcp
# MSFT_MCP_SERVER_URL=

# 🇬🇧 UKG (Ultimate Kronos Group) Remote MCP Server (Optional: set if deployed in Cloud Run)
# Format: https://<your-ukg-run-url>/mcp
# UKG_MCP_SERVER_URL=

# =====================================================================
# Local Fallback Configurations (Only used if URL variables above are empty)
# =====================================================================

# Path relative to this agent's root folder (hr-intake/)
MSFT_MCP_SERVER_PYTHON_PATH=../../msft-mock-api-mcp/.venv/bin/python
MSFT_MCP_SERVER_SCRIPT_PATH=../../msft-mock-api-mcp/mcp/mock_msft_mcp_server.py
# MSFT Mock REST API Base URL and Security Keys
MSFT_API_BASE_URL=http://127.0.0.1:8081
MSFT_API_KEY=mock-auth-token-123

# Path relative to this agent's root folder (hr-intake/)
UKG_MCP_SERVER_PYTHON_PATH=../../ukg-mock-api-mcp/.venv/bin/python
UKG_MCP_SERVER_SCRIPT_PATH=../../ukg-mock-api-mcp/mcp/mock_ukg_mcp_server.py
# UKG Mock REST API Base URL and Security Keys
UKG_API_BASE_URL=http://127.0.0.1:8080
UKG_API_KEY=mock-auth-token-123
